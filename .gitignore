# Rust
target/
**/*.rs.bk

# Node/WASM
node_modules/
dist/
pkg/
modplayer-wasm/pkg/
modplayer-wasm/www/dist/
modplayer-wasm/www/node_modules/
modplayer-wasm/www/modplayer-wasm-app-*.tgz

# OS
.DS_Store
**/.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

# Deployment
.publish/
.aider*
.env

# Scratch / local debug artifacts (state dumps, comparison transcripts,
# loose .rs files used for one-off probes, sample modules pulled in for
# debugging). Not part of any crate.
scratch/
**/scratch/
ft2-clone/

# Auto-regenerated state dumps. `tests/state_dump_test.rs` rewrites these
# on every test run, so keeping them in git just makes every commit diff
# noisy with thousands of unrelated lines. Generate locally as needed.
xmplayer/test_data/*_refactor.txt
xmplayer/test_data/*_dump.txt
xmplayer/test_data/*_master.txt
xmplayer/test_data/*_master_short.txt

# Top-level diagnostic dumps that snuck in during earlier S3M refactor work.
/diff.txt
/test_output.txt
/strshine_*.txt
/channel_master.rs
/xmplayer_master_song.rs

# Corpus harness — modules and renders are big, manifest is generated.
# We track tools/build_corpus.sh and scripts/sweep.py but not the corpus
# contents themselves. corpus/README.md is allow-listed so the directory
# is documented even when empty.
corpus/*.tsv
corpus/*.md
corpus/renders/
corpus/s3m/
corpus/xm/
corpus/it/
corpus/mod/
corpus/stm/
!corpus/README.md
scripts/__pycache__/
